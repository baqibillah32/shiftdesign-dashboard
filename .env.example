# Salin file ini menjadi .env.local dan isi nilainya
# JANGAN commit file .env.local ke GitHub!

# Google Sheets ID (dari URL sheets kamu)
# Contoh URL: https://docs.google.com/spreadsheets/d/1bqgCUPdeoxK7fbs.../edit
# ID-nya adalah bagian setelah /d/ dan sebelum /edit
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# Google Service Account - ambil dari Google Cloud Console
# Paste seluruh JSON credentials sebagai satu baris
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nisi_private_key_kamu\n-----END RSA PRIVATE KEY-----"

# Target omset default (IDR) - bisa diubah dari dashboard
DEFAULT_TARGET=40000000
